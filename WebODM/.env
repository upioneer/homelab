# WebODM Environment Variables
WO_PORT=8000
WO_HOST=localhost
WO_DEBUG=False
WO_DEFAULT_NODES=1

# Storage Variables
WO_DB_DIR=dbdata
WO_MEDIA_DIR=appmedia

# Security
# Generate a random secret key for Django (e.g., using openssl rand -hex 32 or similar)
WO_SECRET_KEY=CHANGEME_YOUR_SECRET_KEY_HERE
